# Django core
DJANGO_SECRET_KEY=replace-with-a-50-char-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Tracy Arm 2025 paper embargo (ISO 8601 with offset)
TRACYARM_EMBARGO_LIFT=2026-05-06T08:00:00-04:00
TRACYARM_YOUTUBE_URL=

# tethys_db (PostGIS) — read-only access for the inventory map.
# Production: copy from /opt/monitoring/.env on the droplet.
# Local dev: copy from /Users/Hig/Docker/tethys-timescale-grafana/.env (host=tethys_db works
#   if the local landslidescience-web container joins tethys-timescale-grafana_internal).
TETHYS_DB_HOST=tethys_db
TETHYS_DB_PORT=5432
LANDSLIDE_DB_NAME=landslides
TETHYS_DB_USERNAME=tethys
TETHYS_DB_PASSWORD=
